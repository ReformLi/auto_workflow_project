/.claude/
# --- 1. 编译后的 Python 文件 ---
*.py[cod]
*$py.class

# --- 2. Python 缓存目录 ---
__pycache__/

# --- 3. PyCharm 的配置文件 ---
# 这些是你个人的IDE设置，不需要分享给别人
.idea/
*.iml

# --- 4. 虚拟环境 (非常重要) ---
# 如果你用 venv, virtualenv, conda 等
venv/
env/
ENV/
.venv/
virtualenv/

# --- 5. 日志和数据库文件 ---
*.log
*.sqlite3
db.sqlite3

# --- 6. 环境变量文件 (包含密钥，绝对不能上传) ---
.env
.env.local

# --- 7. 操作系统生成的文件 ---
.DS_Store
Thumbs.db

# --- 7. 测试文件 ---
tests/
*.json